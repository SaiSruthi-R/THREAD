# ============================================
# Memory Mapping - Environment Configuration
# ============================================
# See CONFIGURATION_GUIDE.md for detailed instructions on getting these values

# ============================================
# AWS CREDENTIALS (Required BEFORE deployment)
# ============================================
# Get these from: AWS Console → IAM → Users → Create user → Programmatic access
# Or use existing credentials from: ~/.aws/credentials
AWS_ACCESS_KEY_ID=your-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
# AWS Region - Choose one with Bedrock support
# Recommended: us-east-1, us-west-2, or eu-west-1
AWS_REGION=us-east-1

# ============================================
# API CONFIGURATION (Get AFTER deployment)
# ============================================
# Get this from CDK output after running: cdk deploy MemoryMappingAPIStack
# Or from: AWS Console → API Gateway → Memory Mapping API → Stages → prod
# Format: https://[api-id].execute-api.[region].amazonaws.com/prod
REACT_APP_API_BASE=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# ============================================
# COGNITO CONFIGURATION (Get AFTER deployment)
# ============================================
# Get these from CDK output after running: cdk deploy MemoryMappingAPIStack
# Or from: AWS Console → Cognito → User pools → memory-mapping-users

# User Pool ID format: [region]_[alphanumeric]
REACT_APP_USER_POOL_ID=us-east-1_ABC123XYZ

# App Client ID format: [alphanumeric string]
REACT_APP_CLIENT_ID=1234567890abcdefghijklmnop

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Get AWS credentials (see CONFIGURATION_GUIDE.md)
# 3. Deploy infrastructure: cd infrastructure/cdk && cdk deploy --all
# 4. Copy API endpoint and Cognito IDs from deployment output
# 5. Update .env with the values
# 6. For frontend, create frontend/.env with REACT_APP_* variables only
#
# For detailed instructions, see: CONFIGURATION_GUIDE.md